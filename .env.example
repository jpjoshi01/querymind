# QueryMind optional local configuration
#
# API keys are not stored in this file anymore.
# On first launch, each user enters their own key in QueryMind.
# The backend saves it in Windows Credential Manager via keytar.

# Optional default provider when more than one saved key exists.
# Allowed values: claude, openai, kimi
DEFAULT_LLM_PROVIDER=openai

# Optional model overrides.
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6
KIMI_MODEL=moonshot-v1-32k

# Optional local port. Electron currently expects 3000.
PORT=3000
